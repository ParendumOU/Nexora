# ─── Database ──────────────────────────────────────────────────
POSTGRES_DB=nexora
POSTGRES_USER=nexora
POSTGRES_PASSWORD=changeme_in_production

# ─── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_in_production

# ─── Backend Security ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-secret-key-here
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ─── CORS ──────────────────────────────────────────────────────
# Local hub: add any port you access Nexora from
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080

# ─── Build target ──────────────────────────────────────────────
# Use 'dev' for development (hot-reload), 'runtime'/'runner' for production
BUILD_TARGET=runtime

# ─── Ports ─────────────────────────────────────────────────────
HTTP_PORT=80

# ─── Frontend ──────────────────────────────────────────────────
# Leave empty in Docker (nginx proxies correctly)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# ─── Environment ───────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info

# ─── Registration gating (optional) ───────────────────────────
# Set to true to require an invite token to register. Users without an invite
# link (generated via POST /api/auth/invite) will be blocked.
# Leave false for open self-hosted deployments.
REQUIRE_INVITE=false

# ─── Agent orchestration limits (optional) ─────────────────────
# MAX_SUBDELEGATION_DEPTH=4            # max agent→sub-agent nesting depth (default: 4)
# PROPOSAL_AUTO_APPROVE_CONFIDENCE=0.85  # confidence threshold for auto-executing proposals (default: 0.85)

# ─── CLI provider rate limiting (optional) ─────────────────────
# Sliding 1-hour window applied to Claude / Gemini / Codex OAuth spawns.
# Fails open when Redis is unavailable (no inference disruption).
# CLI_RATE_LIMIT_PER_USER_PER_HOUR=60
# CLI_RATE_LIMIT_PER_ORG_PER_HOUR=300

# ─── CLI provider security (optional) ──────────────────────────
# Allow CLI-based providers to run in bypass/unrestricted mode:
#   Claude  → --permission-mode bypassPermissions
#   Gemini  → --yolo (auto-approve all tool calls)
#   Codex   → --dangerously-bypass-approvals-and-sandbox
# Default false — omitting these flags keeps each CLI in its safe default mode.
# Set true only in isolated/sandboxed deployments where agents need full FS access.
# WARNING: enables agents to read/write/execute any file inside the container.
ALLOW_CLI_BYPASS_PERMISSIONS=false

# ─── Email (optional — leave SMTP_HOST empty to disable) ────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxx
SMTP_FROM=Nexora <noreply@parendum.com>
SMTP_TLS=true
APP_URL=https://nexora.parendum.com

# ─── Email verification (optional) ────────────────────────────
# When true AND SMTP is configured, new users must verify their email before
# logging in. When SMTP is not configured this is a graceful no-op — users
# are marked verified automatically so the platform remains fully usable.
REQUIRE_EMAIL_VERIFICATION=false

# ─── Telegram Integration (optional) ───────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── GitHub Integration (optional) ─────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ─── GitLab Integration (optional) ─────────────────────────────
GITLAB_APP_ID=
GITLAB_APP_SECRET=
GITLAB_WEBHOOK_SECRET=
