# ─── Database ──────────────────────────────────────────────────
POSTGRES_DB=nexora
POSTGRES_USER=nexora
POSTGRES_PASSWORD=changeme_in_production

# ─── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_in_production

# ─── Backend Security ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-secret-key-here
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ─── CORS ──────────────────────────────────────────────────────
# Local hub: add any port you access Nexora from
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080

# ─── Build target ──────────────────────────────────────────────
# Use 'dev' for development (hot-reload), 'runtime'/'runner' for production
BUILD_TARGET=runtime

# ─── Ports ─────────────────────────────────────────────────────
HTTP_PORT=80

# ─── Frontend ──────────────────────────────────────────────────
# Leave empty in Docker (nginx proxies correctly)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# ─── Environment ───────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info

# ─── Registration gating (optional) ───────────────────────────
# Set to true to require an invite token to register. Users without an invite
# link (generated via POST /api/auth/invite) will be blocked.
# Leave false for open self-hosted deployments.
REQUIRE_INVITE=false

# ─── Agent orchestration limits (optional) ─────────────────────
# MAX_SUBDELEGATION_DEPTH=4            # max agent→sub-agent nesting depth (default: 4)
# PROPOSAL_AUTO_APPROVE_CONFIDENCE=0.85  # confidence threshold for auto-executing proposals (default: 0.85)

# ─── CLI provider rate limiting (optional) ─────────────────────
# Sliding 1-hour window applied to Claude / Gemini / Codex OAuth spawns.
# Fails open when Redis is unavailable (no inference disruption).
# CLI_RATE_LIMIT_PER_USER_PER_HOUR=60
# CLI_RATE_LIMIT_PER_ORG_PER_HOUR=300

# ─── CLI provider security (optional) ──────────────────────────
# Allow CLI-based providers to run in bypass/unrestricted mode:
#   Claude  → --permission-mode bypassPermissions
#   Gemini  → --yolo (auto-approve all tool calls)
#   Codex   → --dangerously-bypass-approvals-and-sandbox
# Default false — omitting these flags keeps each CLI in its safe default mode.
# Set true only in isolated/sandboxed deployments where agents need full FS access.
# WARNING: enables agents to read/write/execute any file inside the container.
ALLOW_CLI_BYPASS_PERMISSIONS=false

# ─── Email (optional — leave SMTP_HOST empty to disable) ────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxx
SMTP_FROM=Nexora <noreply@parendum.com>
SMTP_TLS=true
APP_URL=https://nexora.parendum.com

# ─── Email verification (optional) ────────────────────────────
# When true AND SMTP is configured, new users must verify their email before
# logging in. When SMTP is not configured this is a graceful no-op — users
# are marked verified automatically so the platform remains fully usable.
REQUIRE_EMAIL_VERIFICATION=false

# ─── Telegram Integration (optional) ───────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── GitHub Integration (optional) ─────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ─── GitLab Integration (optional) ─────────────────────────────
GITLAB_APP_ID=
GITLAB_APP_SECRET=
GITLAB_WEBHOOK_SECRET=

# ─── Feature flags (optional) ──────────────────────────────────
# As of v1.9.0 the four flags below default ON (validated in production). Set any
# to false to restore the older behavior. RUN_QUEUE_ENABLED stays OFF — it needs a
# separate runner process, so opt in only when you run one.

# Provider-native function calling (GitLab #214). Sends an agent's schema-backed
# tools via the provider's native tool API (Anthropic/OpenAI/Gemini) and converts
# the calls back to the internal ```tool_calls fence. Tools without a declared
# schema stay on the text-fence path. Default true; set false for the legacy fence.
NATIVE_TOOLS_ENABLED=true

# System-prompt caching (GitLab #220). Inserts a cache breakpoint after the static
# tool/intro block so the Anthropic API path reuses that prefix across tool-resume
# turns (cache_control: ephemeral) instead of re-billing it. No-op off-Anthropic.
# Default true; set false for a byte-identical prompt with no cache split.
PROMPT_CACHE_ENABLED=true

# Event-driven sub-agent delegation (GitLab #218). A delegating parent waits on a
# Redis child-done signal (waking promptly, ~no DB load) instead of polling Postgres
# once per second for up to 300s. Default true; set false for the legacy 1s poll.
EVENT_DRIVEN_DELEGATION=true

# Durable run queue + dedicated runner workers + cross-worker concurrency governor
# (GitLab #219/#218). When on, background runs (sub-agent dispatch, orchestrator
# resumes, nested delegation) are pushed to a Redis Stream and executed by dedicated
# runner workers (run one or more with: `python -m src.runner`) instead of in-process
# tasks. Gives durable-across-restart runs, a cross-worker concurrency cap, and
# deadlock-free nested delegation (a parent releases its governor slot while waiting
# for children). Default false (in-process execution). Runner tuning (only relevant
# when RUN_QUEUE_ENABLED=true):
RUN_QUEUE_ENABLED=false
# RUN_QUEUE_STREAM=nexora:runs        # Redis Stream name for queued runs
# RUN_QUEUE_GROUP=runners             # consumer group name
# RUNNER_CONCURRENCY=4                # concurrent runs per runner worker
# RUNNER_CLAIM_MIN_IDLE_MS=120000     # reclaim a run abandoned by a dead runner after this

# Parallel read-tier tool execution (GitLab #229). Side-effect-free read tools
# (file_read, board_read, knowledge_search, github/gitlab read, …) in one turn run
# concurrently; events, ordering, and gating are unchanged. Default true; set false
# for the fully sequential path.
PARALLEL_TOOL_CALLS_ENABLED=true

# Shared agent workspace (GitLab #240). When true, the in-container filesystem/shell
# tools (shell_run, file_read/write/list) operate inside ONE persistent directory per
# project (proj_<id>) — or per root chat (chat_<root>) without a project — under
# /workspaces. An agent and all its sub-agents share it and it survives restarts, so a
# team can build a real git-backed codebase together (git ships in the image). Relative
# tool paths resolve under it; absolute paths still work. The CLI local-exec path keeps
# the client's cwd. Default false (tools use the container-default cwd).
SHARED_WORKSPACE_ENABLED=false

# Deterministic task auto-assignment (model-agnostic orchestration). When a delegated
# task names no agent, the platform routes it to the best-fit specialist by capability
# (skills/tools/role) with a capable-"doer" fallback, instead of leaving it unassigned.
# Default true. Set false to require the model to name the agent.
AUTO_ASSIGN_AGENTS=true

# ─── Autonomy (optional — default OFF) ─────────────────────────
# Proactive goal-driven tick. When on, the platform periodically advances open
# goals. AUTONOMY_DISPATCH_ENABLED additionally lets the tick spawn a goal's owner
# agent toward its next milestone (requires the tick too). For unattended runs only.
AUTONOMY_TICK_ENABLED=false
AUTONOMY_DISPATCH_ENABLED=false
AUTONOMY_TICK_INTERVAL_MINUTES=5
# Acceptance-criteria verification loop: a failing sub-agent turn is bounced back
# with feedback up to MAX_VERIFICATION_RETRIES times (GitLab #233).
TASK_VERIFICATION_ENABLED=false

# ─── Tool governance / risk policy (optional — default OFF) ────
# Human-in-the-loop approval: tools at/above this risk tier are held for review
# before running. One of: "" (off) | read | write | external | exec. (GitLab #235)
REQUIRE_APPROVAL_TIER=
# Hard-deny whole risk tiers for an unattended deployment (GitLab #222/#235).
DENY_EXEC_TOOLS=false        # block shell_run, code_*, docker_*
DENY_EXTERNAL_TOOLS=false    # block slack, jira, http_request, s3, k8s, …
# Default-deny: an agent with NO configured tools gets only always-allowed coordination
# tools + its own skills (instead of the full builtin set). (GitLab #222)
TOOLS_DEFAULT_DENY=false
