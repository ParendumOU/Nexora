{
  "key": "gemini",
  "name": "Gemini (Google)",
  "description": "Google Gemini models via CLI OAuth — uses your Google account",
  "auth_type": "oauth",
  "stream_type": "gemini",
  "base_url": null,
  "requires_base_url": false,
  "default_model": "gemini-2.5-flash",
  "models": ["gemini-2.5-flash", "gemini-2.5-pro", "gemini-2.0-flash"],
  "cli_command": "gemini",
  "cli_login_args": ["--yolo"],
  "credential_paths": [
    ".gemini/oauth_creds.json"
  ],
  "credential_format": "raw_json",
  "website": "https://ai.google.dev"
}
