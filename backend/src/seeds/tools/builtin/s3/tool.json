{
  "key": "s3",
  "name": "S3 / Object Storage",
  "description": "Read and write S3-compatible object storage — list buckets/objects, read text files, upload, delete, and generate presigned URLs. Works with AWS S3, MinIO, Cloudflare R2, and any S3-compatible endpoint.",
  "category": "data",
  "env_vars": [
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_ENDPOINT",
    "S3_BUCKET"
  ],
  "is_builtin": true,
  "platform_executor": true,
  "args": [
    {
      "name": "action",
      "type": "string",
      "required": true,
      "description": "action"
    },
    {
      "name": "bucket",
      "type": "string",
      "description": "bucket"
    },
    {
      "name": "key",
      "type": "string",
      "description": "key"
    },
    {
      "name": "prefix",
      "type": "string",
      "description": "prefix"
    },
    {
      "name": "content",
      "type": "string",
      "description": "content"
    },
    {
      "name": "content_type",
      "type": "string",
      "description": "content type"
    },
    {
      "name": "expires_in",
      "type": "integer",
      "description": "expires in"
    },
    {
      "name": "limit",
      "type": "integer",
      "description": "limit"
    }
  ]
}
