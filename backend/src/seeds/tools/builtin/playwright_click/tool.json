{
  "key": "playwright_click",
  "name": "Browser Click",
  "description": "Click an element on a page in a headless browser session.",
  "category": "browser",
  "env_vars": [],
  "is_builtin": true,
  "args": [
    {
      "name": "session_id",
      "type": "string",
      "required": true,
      "description": "Active browser session id."
    },
    {
      "name": "selector",
      "type": "string",
      "required": true,
      "description": "CSS selector of element to click."
    },
    {
      "name": "timeout",
      "type": "integer",
      "required": false,
      "description": "Milliseconds (default 5000)."
    }
  ]
}
