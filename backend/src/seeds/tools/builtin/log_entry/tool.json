{
  "key": "log_entry",
  "name": "Log Entry",
  "description": "Emit a structured log entry visible in the agent activity panel.",
  "category": "platform",
  "env_vars": [],
  "is_builtin": true,
  "always_allowed": true,
  "args": [
    {
      "name": "message",
      "type": "string",
      "required": false,
      "description": "The log message to record."
    },
    {
      "name": "level",
      "type": "string",
      "required": false,
      "description": "info | warning | error (default info)."
    },
    {
      "name": "data",
      "type": "object",
      "required": false,
      "description": "Optional structured payload."
    }
  ]
}
