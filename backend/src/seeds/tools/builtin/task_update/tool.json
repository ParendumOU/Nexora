{
  "key": "task_update",
  "name": "Task Update",
  "description": "Update the status, priority, blockers, or result of an existing task. Fields: task_id*, title, description, status (pending|queued|running|paused|completed|failed), priority (low|medium|high|critical), blocked_by (list of task IDs), output, checklist.",
  "category": "platform",
  "env_vars": [],
  "is_builtin": true,
  "always_allowed": true,
  "args": [
    {
      "name": "task_id",
      "type": "string",
      "required": true,
      "description": "The task to update."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "pending | in_progress | completed | failed | cancelled."
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "description": "New title."
    },
    {
      "name": "description",
      "type": "string",
      "required": false,
      "description": "New description."
    },
    {
      "name": "priority",
      "type": "string",
      "required": false,
      "description": "low | medium | high | critical."
    }
  ]
}
