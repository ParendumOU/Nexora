{
  "key": "gitlab_list_mrs",
  "name": "GitLab List Merge Requests",
  "description": "List merge requests for a GitLab project.",
  "category": "gitlab",
  "group": "gitlab_read",
  "env_vars": [
    "GITLAB_TOKEN"
  ],
  "is_builtin": true,
  "platform_executor": true,
  "args": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "description": "Project ID or path."
    },
    {
      "name": "state",
      "type": "string",
      "required": false,
      "description": "opened | closed | merged | all (default opened)."
    },
    {
      "name": "target_branch",
      "type": "string",
      "required": false,
      "description": "Filter by target branch."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page (default 20, max 100)."
    }
  ]
}
