{
  "key": "chat_notes",
  "name": "Chat Notes",
  "description": "Read or write shared notes for this conversation. Notes are stored on the root chat and visible to all sub-agents in the same chat tree.",
  "category": "memory",
  "is_builtin": true,
  "always_allowed": true,
  "args": [
    {
      "name": "action",
      "type": "string",
      "required": true,
      "description": "read | write | append."
    },
    {
      "name": "content",
      "type": "string",
      "required": false,
      "description": "[write/append] Note body."
    },
    {
      "name": "heading",
      "type": "string",
      "required": false,
      "description": "[write/append] Optional note heading."
    }
  ]
}
