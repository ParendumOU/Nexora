{
  "key": "outcome_record",
  "name": "Outcome Record",
  "description": "Record an outcome or decision for the learning loop. Fields: subject*, kind (outcome|decision), status (success|failure|partial|info), detail (what happened / why), metric_name, metric_value (number), ref_type (goal|task|action), ref_id.",
  "category": "platform",
  "env_vars": [],
  "is_builtin": true,
  "always_allowed": true,
  "args": [
    {
      "name": "subject",
      "type": "string",
      "required": true,
      "description": "What the outcome is about."
    },
    {
      "name": "kind",
      "type": "string",
      "required": false,
      "description": "outcome | decision | observation (default outcome)."
    },
    {
      "name": "status",
      "type": "string",
      "required": false,
      "description": "info | success | failure | partial (default info)."
    },
    {
      "name": "detail",
      "type": "string",
      "required": false,
      "description": "Free-text detail."
    },
    {
      "name": "metric_name",
      "type": "string",
      "required": false,
      "description": "Optional KPI name."
    },
    {
      "name": "metric_value",
      "type": "number",
      "required": false,
      "description": "Optional KPI value."
    },
    {
      "name": "ref_type",
      "type": "string",
      "required": false,
      "description": "Linked entity type (goal, task, ...)."
    },
    {
      "name": "ref_id",
      "type": "string",
      "required": false,
      "description": "Linked entity id."
    }
  ]
}
