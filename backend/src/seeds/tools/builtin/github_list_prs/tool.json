{
  "key": "github_list_prs",
  "name": "GitHub List Pull Requests",
  "description": "List pull requests for a GitHub repository with optional filtering by state and base branch.",
  "category": "github",
  "group": "github_read",
  "env_vars": [
    "GITHUB_TOKEN"
  ],
  "is_builtin": true,
  "platform_executor": true,
  "args": [
    {
      "name": "owner",
      "type": "string",
      "required": true,
      "description": "Repo owner."
    },
    {
      "name": "repo",
      "type": "string",
      "required": true,
      "description": "Repo name."
    },
    {
      "name": "state",
      "type": "string",
      "required": false,
      "description": "open | closed | all (default open)."
    },
    {
      "name": "base",
      "type": "string",
      "required": false,
      "description": "Filter by base branch."
    },
    {
      "name": "per_page",
      "type": "integer",
      "required": false,
      "description": "Results per page (default 30, max 100)."
    }
  ]
}
