{
  "key": "gitlab_read_file",
  "name": "GitLab Read File",
  "description": "Read the content of a file from a GitLab repository at a specific ref.",
  "category": "gitlab",
  "group": "gitlab_read",
  "env_vars": [
    "GITLAB_TOKEN"
  ],
  "is_builtin": true,
  "platform_executor": true,
  "args": [
    {
      "name": "project_id",
      "type": "string",
      "required": true,
      "description": "Project ID or path."
    },
    {
      "name": "file_path",
      "type": "string",
      "required": true,
      "description": "File path within repo."
    },
    {
      "name": "ref",
      "type": "string",
      "required": false,
      "description": "Branch, tag, or commit SHA (default branch)."
    }
  ]
}
